# Extensiones que SOLO pueden venir del dispositivo
*.ab
*.tar
*.sha256
*.crypt12
*.crypt14
*.crypt15
*.bkup
*.was

# Bases de datos sensibles
*.db
*.db-journal
*.db-shm
*.db-wal
msgstore*
wa.db*
chatsettingsbackup*
commerce_backup*
status_backup*
chatlock_backup*

# EXCEPCIONES: estos SI se commitean
# (los APKs candidatos legacy son publicos, deben estar en el repo)
!legacy_apk/*.apk

# Script antiguo superado por forense_android.py
wa_extractor.py

# Script antiguo superado por forense_android.py
wa_extractor.py

# Mantener carpetas vacias si no hay archivos
!abe/.gitkeep

